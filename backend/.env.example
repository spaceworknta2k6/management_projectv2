PORT=5002
NODE_ENV=development

# CORS Config (Địa chỉ URL của dự án Frontend ReactJS để cho phép truy cập)
FRONTEND_URL=http://localhost:3002

# JWT Security Config (Xác thực Stateless JWT)
JWT_SECRET=your_jwt_secret_key_should_be_at_least_32_characters
JWT_EXPIRES_IN=7d

# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=verify-full"

# Upload & Cloud Storage Config
UPLOAD_DIR=public/uploads
MAX_FILE_SIZE=10485760
STORAGE_PROVIDER=cloudinary
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google OAuth2 Config
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5002/api/v1/auth/google/callback
